---
import TechTag from "./TechTag.astro";
import { getBackgroundSlug, type BackgroundItem } from "../utils";

interface Props {
  items: BackgroundItem[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
const getCompactDates = (period: string) => {
  const [start, end = ""] = period.split(" - ");
  return { start, end };
};
---

<ol class:list={["timeline-list", compact && "timeline-list-compact"]} data-reveal-group>
  {items.map((item) => {
    const dates = getCompactDates(item.period);
    const slug = getBackgroundSlug(item);
    const detailHref = `/about/${slug}/`;

    return (
      <li class="timeline-item">
        {compact && (
          <>
            <p class="timeline-date timeline-date-start">{dates.end}</p>
            <p class="timeline-date timeline-date-end">{dates.start}</p>
          </>
        )}
        <div class:list={["timeline-marker", compact && "timeline-marker-start"]} aria-hidden="true"></div>
        {compact && <div class="timeline-marker timeline-marker-end" aria-hidden="true"></div>}
        <div class="timeline-content timeline-content-clickable">
          <a class="timeline-card-link" href={detailHref} aria-label={`Read more about ${item.organization}`}></a>
          <div class="timeline-heading">
            <div>
              {compact ? (
                <div class="timeline-title-block">
                  <h3>{item.role}</h3>
                  <a href={item.url} target="_blank" rel="noreferrer">{item.organization}</a>
                </div>
              ) : (
                <>
                  <p class="timeline-period">{item.period}</p>
                  <h3>{item.role}</h3>
                  <a href={item.url} target="_blank" rel="noreferrer">{item.organization}</a>
                </>
              )}
            </div>
            <img
              class:list={["timeline-logo", item.logo.includes("clevoy") && "timeline-logo-wide"]}
              src={item.logo}
              alt={`${item.organization} logo`}
              loading="lazy"
            />
          </div>
          {compact && <p>{item.summary}</p>}
          {!compact && (
            <>
              <p>{item.summary}</p>
              <ul class="feature-list">
                {item.details.map((detail) => <li>{detail}</li>)}
              </ul>
              <div class="tag-list">
                {item.tags.map((tag) => <TechTag tag={tag} muted />)}
              </div>
            </>
          )}
        </div>
      </li>
    );
  })}
</ol>
