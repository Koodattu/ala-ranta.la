---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "./ProjectCard.astro";
import Timeline from "./Timeline.astro";
import { homeCopy, localizedEducation, localizedExperience, type Locale } from "../data/home";
import { education, experience, profile } from "../data/profile";
import projectsData from "../data/projects.json";
import { getBackgroundSlug, sortNewestProjects, type Project } from "../utils";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = homeCopy[locale];
const projects = sortNewestProjects(projectsData.projects as Project[]).map((project) => ({
  ...project,
  ...copy.projects.translations[project.title],
}));
const selectedWorkProjectTitles = ["WoW Guild Progress Tracker", "Unity 3D AI Assistant", "Voice Guided Imaging"];
const selectedWorkProjects = projects
  .filter((project) => selectedWorkProjectTitles.includes(project.title))
  .sort((a, b) => selectedWorkProjectTitles.indexOf(a.title) - selectedWorkProjectTitles.indexOf(b.title));
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const linkedinUrl = profile.socials.find((social) => social.label === "LinkedIn")?.href ?? "/";
const currentLogo = experience[0];
const previousLogos = [...experience.slice(1), ...education].filter(
  (item, index, items) => items.findIndex((candidate) => candidate.organization === item.organization) === index,
);
const alternates = [
  { lang: "en", href: "/" },
  { lang: "fi", href: "/fi/" },
];
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  lang={copy.lang}
  alternates={alternates}
  xDefaultHref="/"
  enableLocaleRedirect={locale === "en"}
>
  <main>
    <section class="hero section-shell" aria-labelledby="intro-title">
      <div class="hero-copy reveal">
        <p class="eyebrow">{copy.hero.eyebrow}</p>
        <h1 id="intro-title">{profile.name}</h1>
        <p class="hero-statement">{copy.hero.statement}</p>
        <p class="hero-lede">{copy.hero.lede}</p>
        <div class="hero-actions" aria-label={copy.hero.actionsLabel}>
          <div class="hero-action-row hero-action-row-primary">
            <a class="button button-primary" href="#selected-work">{copy.hero.selectedWork}</a>
            <a class="button button-linkedin" href={linkedinUrl} target="_blank" rel="noreferrer">
              <span>{copy.hero.linkedinPrefix}</span>
              <img class="button-logo" src="/assets/linkedin.webp" alt="" />
              <span>{copy.hero.linkedinSuffix}</span>
            </a>
          </div>
          <div class="hero-action-row hero-action-row-secondary">
            <a class="button button-quiet" href="/blog/">{copy.hero.blog}</a>
            <a class="button button-quiet" href={`mailto:${profile.email}`}>{copy.hero.email}</a>
            <a class="button button-quiet" href={profile.cv[locale]}>{copy.hero.cv}</a>
          </div>
        </div>
        <dl class="hero-proof" aria-label={copy.hero.proofLabel}>
          <div>
            <dt>{copy.hero.current}</dt>
            <dd>
              <div class="proof-logo-list">
                <a class="proof-logo proof-logo-current" href={`/about/${getBackgroundSlug(currentLogo)}/`} aria-label={currentLogo.organization}>
                  <img src={currentLogo.logo} alt="" loading="lazy" />
                </a>
              </div>
            </dd>
          </div>
          <div>
            <dt>{copy.hero.previous}</dt>
            <dd>
              <div class="proof-logo-list">
                {previousLogos.map((item) => (
                  <a class="proof-logo" href={`/about/${getBackgroundSlug(item)}/`} aria-label={item.organization}>
                    <img src={item.logo} alt="" loading="lazy" />
                  </a>
                ))}
              </div>
            </dd>
          </div>
        </dl>
      </div>

      <div class="hero-visual reveal" aria-hidden="true">
        <div class="hero-portrait-panel">
          <img class="hero-photo" src="/assets/big-photo.png" alt="" />
        </div>
      </div>
    </section>

    <section class="section-shell compact-section" aria-labelledby="focus-title">
      <a class="section-heading section-heading-row section-heading-action-row section-heading-link" href="/about/" data-reveal>
        <div>
          <p class="eyebrow">{copy.focus.eyebrow}</p>
          <h2 id="focus-title">{copy.focus.title}</h2>
        </div>
        <span class="text-link text-link-outbound section-heading-link-action">
          <span>{copy.focus.about}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M7 17 17 7" />
            <path d="M9 7h8v8" />
          </svg>
        </span>
      </a>
      <div class="focus-grid focus-grid-current" data-reveal-group>
        {copy.focus.items.map((area) => (
          <a class="focus-card focus-card-link" href={area.href} aria-label={`${copy.focus.readMore}: ${area.title}`}>
            <h3>{area.title}</h3>
            <p>{area.text}</p>
            <span class="timeline-read-more focus-read-more" aria-hidden="true">
              <span>{copy.focus.readMore}</span>
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M5 12h14" />
                <path d="m13 6 6 6-6 6" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-shell" id="selected-work" aria-labelledby="projects-title">
      <a class="section-heading section-heading-row section-heading-action-row section-heading-link" href="/projects/" data-reveal>
        <div>
          <p class="eyebrow">{copy.projects.eyebrow}</p>
          <h2 id="projects-title">{copy.projects.title}</h2>
        </div>
        <span class="text-link text-link-outbound section-heading-link-action">
          <span>{copy.projects.all}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M7 17 17 7" />
            <path d="M9 7h8v8" />
          </svg>
        </span>
      </a>
      <div class="work-grid" data-reveal-group>
        {selectedWorkProjects.map((project) => (
          <ProjectCard project={project} labels={copy.projects.cardLabels} selectedWork={copy.projects.spotlight[project.title]} />
        ))}
      </div>
    </section>

    <section class="section-shell" aria-labelledby="writing-title">
      <a class="section-heading section-heading-row section-heading-action-row section-heading-link" href="/blog/" data-reveal>
        <div>
          <p class="eyebrow">{copy.writing.eyebrow}</p>
          <h2 id="writing-title">{copy.writing.title}</h2>
        </div>
        <span class="text-link text-link-outbound section-heading-link-action">
          <span>{copy.writing.archive}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M7 17 17 7" />
            <path d="M9 7h8v8" />
          </svg>
        </span>
      </a>
      {
        posts.length > 0 ? (
          <div class="writing-row" data-reveal-group>
            {posts.map((post) => (
              <a class="writing-item" href={`/blog/${post.id}/`}>
                <div class="writing-item-title">
                  <p class="post-meta">
                    {post.data.pubDate.toLocaleDateString(copy.locale, { year: "numeric", month: "long", day: "numeric" })}
                  </p>
                  <h3>{post.data.title}</h3>
                </div>
                <p class="writing-item-description">{post.data.description}</p>
                <span class="timeline-read-more writing-read-more" aria-hidden="true">
                  <span>{copy.timeline.readMore}</span>
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M5 12h14" />
                    <path d="m13 6 6 6-6 6" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        ) : (
          <p>{copy.writing.empty}</p>
        )
      }
    </section>

    <section class="section-shell timeline-preview-section" aria-label={copy.timeline.ariaLabel}>
      <div class="timeline-preview-list">
        <section class="timeline-preview" aria-labelledby="work-history-preview-title">
          <div class="timeline-preview-heading" data-reveal>
            <a class="timeline-preview-heading-link" href="/about/#work" aria-label={copy.timeline.experienceAction}>
              <p class="eyebrow">{copy.timeline.experienceEyebrow}</p>
              <h2 id="work-history-preview-title">{copy.timeline.experienceTitle}</h2>
              <span class="timeline-read-more timeline-heading-read-more" aria-hidden="true">
                <span>{copy.timeline.experienceAction}</span>
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14" />
                  <path d="m13 6 6 6-6 6" />
                </svg>
              </span>
            </a>
          </div>
          <Timeline items={localizedExperience[locale]} compact readMoreLabel={copy.timeline.readMore} readMoreAriaPrefix={copy.timeline.readMoreAriaPrefix} />
        </section>
        <section class="timeline-preview" aria-labelledby="studies-preview-title">
          <div class="timeline-preview-heading" data-reveal>
            <a class="timeline-preview-heading-link" href="/about/#studies" aria-label={copy.timeline.educationAction}>
              <p class="eyebrow">{copy.timeline.educationEyebrow}</p>
              <h2 id="studies-preview-title">{copy.timeline.educationTitle}</h2>
              <span class="timeline-read-more timeline-heading-read-more" aria-hidden="true">
                <span>{copy.timeline.educationAction}</span>
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14" />
                  <path d="m13 6 6 6-6 6" />
                </svg>
              </span>
            </a>
          </div>
          <Timeline items={localizedEducation[locale]} compact readMoreLabel={copy.timeline.readMore} readMoreAriaPrefix={copy.timeline.readMoreAriaPrefix} />
        </section>
      </div>
    </section>

    <section class="section-shell contact-section" aria-labelledby="contact-title">
      <div class="contact-panel" data-reveal>
        <div>
          <p class="eyebrow">{copy.contact.eyebrow}</p>
          <h2 id="contact-title">{copy.contact.title}</h2>
          <p>{copy.contact.text}</p>
        </div>
        <div class="contact-actions" aria-label={copy.contact.actionsLabel}>
          <a class="button button-primary" href={`mailto:${profile.email}`}>{copy.contact.email}</a>
          <a class="button button-linkedin" href={linkedinUrl} target="_blank" rel="noreferrer">
            <img class="button-logo" src="/assets/linkedin.webp" alt="" />
            <span>{copy.contact.linkedin}</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
