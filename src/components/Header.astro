---
import { profile } from "../data/profile";

interface Props {
  lang?: "en" | "fi";
  languageHrefs?: Partial<Record<"en" | "fi", string>>;
}

const { lang = "en", languageHrefs = {} } = Astro.props;
const pathname = Astro.url.pathname;

const headerCopy = {
  en: {
    navLabel: "Primary navigation",
    actionsLabel: "Header actions",
    languageLabel: "Language",
    projectsLabel: "Projects",
    blogLabel: "Blog",
    aboutLabel: "About",
    homeAria: `${profile.siteName} home`,
    cvAria: "Download English CV",
  },
  fi: {
    navLabel: "Päänavigaatio",
    actionsLabel: "Yläosan toiminnot",
    languageLabel: "Kieli",
    projectsLabel: "Projektit",
    blogLabel: "Blogi",
    aboutLabel: "Tietoa",
    homeAria: `${profile.siteName} etusivu`,
    cvAria: "Lataa suomenkielinen CV",
  },
};

const copy = headerCopy[lang];
const hasBrandPrefix = profile.handle.startsWith("_");
const brandPrefix = hasBrandPrefix ? "_" : "";
const brandName = hasBrandPrefix ? profile.handle.slice(1) : profile.handle;
const navItems = [
  {
    href: { en: "/projects/", fi: "/projects/" },
    label: { en: headerCopy.en.projectsLabel, fi: headerCopy.fi.projectsLabel },
  },
  {
    href: { en: "/blog/", fi: "/blog/" },
    label: { en: headerCopy.en.blogLabel, fi: headerCopy.fi.blogLabel },
  },
  {
    href: { en: "/about/", fi: "/about/" },
    label: { en: headerCopy.en.aboutLabel, fi: headerCopy.fi.aboutLabel },
  },
];

const isActive = (href: string) => href === "/" ? pathname === "/" : pathname.startsWith(href);
const homeHref = lang === "fi" ? "/fi/" : "/";
const languageHref = (targetLang: "en" | "fi") => {
  const localizedHref = languageHrefs[targetLang];

  if (localizedHref) {
    return localizedHref;
  }

  if (pathname === "/") {
    return targetLang === "fi" ? "/fi/" : "/?lang=en";
  }

  if (pathname === "/fi/") {
    return targetLang === "en" ? "/?lang=en" : "/fi/";
  }

  return `${pathname}?lang=${targetLang}`;
};
---

<header class="site-header">
  <a
    class="brand"
    href={homeHref}
    aria-label={copy.homeAria}
    aria-current={isActive(homeHref) ? "page" : undefined}
    data-language-aria-en={headerCopy.en.homeAria}
    data-language-aria-fi={headerCopy.fi.homeAria}
    data-language-href-en="/"
    data-language-href-fi="/fi/"
  >
    <span class="brand-text">
      {brandPrefix && <span class="brand-prefix">{brandPrefix}</span>}
      <span>{brandName}</span>
    </span>
  </a>
  <nav
    class="site-nav"
    aria-label={copy.navLabel}
    data-language-aria-en={headerCopy.en.navLabel}
    data-language-aria-fi={headerCopy.fi.navLabel}
  >
    {navItems.map((item) => (
      <a
        href={item.href[lang]}
        aria-current={isActive(item.href[lang]) ? "page" : undefined}
        data-language-href-en={item.href.en}
        data-language-href-fi={item.href.fi}
      >
        <span data-language-copy="en">{item.label.en}</span>
        <span data-language-copy="fi">{item.label.fi}</span>
      </a>
    ))}
  </nav>
  <div
    class="header-actions"
    aria-label={copy.actionsLabel}
    data-language-aria-en={headerCopy.en.actionsLabel}
    data-language-aria-fi={headerCopy.fi.actionsLabel}
  >
    <nav
      class="language-switcher"
      aria-label={copy.languageLabel}
      data-language-aria-en={headerCopy.en.languageLabel}
      data-language-aria-fi={headerCopy.fi.languageLabel}
    >
      <a href={languageHref("en")} data-language-choice="en" aria-current={lang === "en" ? "true" : undefined}>EN</a>
      <a href={languageHref("fi")} data-language-choice="fi" aria-current={lang === "fi" ? "true" : undefined}>FI</a>
    </nav>
    <a
      class="icon-link"
      href={profile.cv[lang]}
      aria-label={copy.cvAria}
      data-language-aria-en={headerCopy.en.cvAria}
      data-language-aria-fi={headerCopy.fi.cvAria}
      data-language-href-en={profile.cv.en}
      data-language-href-fi={profile.cv.fi}
    >
      CV
    </a>
  </div>
</header>
