---
interface Props {
  sectionHref: string;
  sectionLabel: string;
  ariaLabel: string;
  sectionLabelFi?: string;
  ariaLabelFi?: string;
  previousLabel?: string;
  previousLabelFi?: string;
}

const {
  sectionHref,
  sectionLabel,
  ariaLabel,
  sectionLabelFi = sectionLabel,
  ariaLabelFi = ariaLabel,
  previousLabel = "Back to previous",
  previousLabelFi = previousLabel,
} = Astro.props;
---

<nav
  class="detail-back-nav section-shell"
  aria-label={ariaLabel}
  data-language-aria-en={ariaLabel}
  data-language-aria-fi={ariaLabelFi}
>
  <button class="button button-quiet detail-previous-button" type="button" data-previous-page disabled>
    <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 12H5" />
      <path d="M12 19l-7-7 7-7" />
    </svg>
    <span data-language-copy="en">{previousLabel}</span>
    <span data-language-copy="fi">{previousLabelFi}</span>
  </button>
  <a class="button button-quiet" href={sectionHref}>
    <span data-language-copy="en">{sectionLabel}</span>
    <span data-language-copy="fi">{sectionLabelFi}</span>
  </a>
</nav>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-previous-page]").forEach((button) => {
    if (!document.referrer) {
      button.setAttribute("aria-disabled", "true");
      return;
    }

    button.disabled = false;
    button.removeAttribute("aria-disabled");
    button.addEventListener("click", () => window.history.back());
  });
</script>
