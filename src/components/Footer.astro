---
import { profile } from "../data/profile";

interface Props {
  lang?: "en" | "fi";
}

const { lang = "en" } = Astro.props;
const footerCopy = {
  en: {
    built: "Built as a static Astro site. Source code is available on",
    repoLabel: "GitHub",
    links: "Footer links",
  },
  fi: {
    built: "Rakennettu staattisena Astro-sivustona. Lähdekoodi on saatavilla",
    repoLabel: "GitHubissa",
    links: "Alatunnisteen linkit",
  },
};

const copy = footerCopy[lang];
---

<footer class="site-footer">
  <p>
    <span data-language-copy="en">{footerCopy.en.built}</span>
    <span data-language-copy="fi">{footerCopy.fi.built}</span>
    <a href={profile.repo} target="_blank" rel="noreferrer">
      <span data-language-copy="en">{footerCopy.en.repoLabel}</span>
      <span data-language-copy="fi">{footerCopy.fi.repoLabel}</span>
    </a>.
  </p>
  <nav aria-label={copy.links} data-language-aria-en={footerCopy.en.links} data-language-aria-fi={footerCopy.fi.links}>
    {profile.socials.map((social) => (
      <a href={social.href} target={social.href.startsWith("http") ? "_blank" : undefined} rel={social.href.startsWith("http") ? "noreferrer" : undefined}>
        {social.label}
      </a>
    ))}
  </nav>
</footer>
