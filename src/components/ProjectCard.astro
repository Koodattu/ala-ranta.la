---
import TechTag from "./TechTag.astro";
import { getProjectSlug, getProjectTags, projectImagePath, slugify, type Project } from "../utils";

interface Props {
  project: Project;
  compact?: boolean;
  labels?: {
    source: string;
    project: string;
    readAbout: string;
    preview: string;
    features: string;
    technologies: string;
  };
}

const {
  project,
  compact = false,
  labels = {
    source: "Source",
    project: "Project",
    readAbout: "Read about",
    preview: "preview",
    features: "features",
    technologies: "technologies",
  },
} = Astro.props;
const tags = getProjectTags(project);
const slug = getProjectSlug(project);
const sourceLabel = project.link.includes("github.com") ? labels.source : labels.project;
---

<article
  class:list={["project-card", compact && "project-card-compact"]}
  data-project-card
  data-title={project.title.toLowerCase()}
  data-description={project.description.toLowerCase()}
  data-tags={tags.map(slugify).join(" ")}
>
  <a class="project-media" href={`/projects/${slug}/`} aria-label={`${labels.readAbout} ${project.title}`}>
    <img
      src={projectImagePath(project)}
      alt={`${project.title} ${labels.preview}`}
      loading="lazy"
      style={`view-transition-name: vt-project-${slug};`}
    />
  </a>
  <div class="project-card-body">
    <div class="project-card-topline">
      <span>{project.year}</span>
      <a href={project.link} target="_blank" rel="noreferrer">{sourceLabel}</a>
    </div>
    <h3><a href={`/projects/${slug}/`}>{project.title}</a></h3>
    <p>{project.description}</p>
    {!compact && (
      <ul class="feature-list" aria-label={`${project.title} ${labels.features}`}>
        {project.features.slice(0, 3).map((feature) => <li>{feature}</li>)}
      </ul>
    )}
    <div class="tag-list" aria-label={`${project.title} ${labels.technologies}`}>
      {tags.slice(0, compact ? 5 : 8).map((tag) => <TechTag tag={tag} />)}
    </div>
  </div>
</article>
