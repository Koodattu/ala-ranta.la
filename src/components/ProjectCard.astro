---
import { getProjectSlug, projectImagePath, type Project } from "../utils";

interface Props {
  project: Project;
  compact?: boolean;
  selectedWork?: {
    paragraphs?: string[];
  };
  labels?: {
    source: string;
    blog: string;
    demo: string;
    readAbout: string;
    readMore: string;
    preview: string;
  };
}

const {
  project,
  compact = false,
  selectedWork,
  labels = {
    source: "Source",
    blog: "Blog",
    demo: "Demo",
    readAbout: "Read about",
    readMore: "Read more",
    preview: "preview",
  },
} = Astro.props;
const slug = getProjectSlug(project);
const selectedParagraphs = selectedWork?.paragraphs ?? [project.description];
const actions = [
  { label: labels.source, href: project.source, external: true, ariaLabel: `Open ${project.title} source on GitHub` },
  { label: labels.blog, href: project.blog, external: false, ariaLabel: `Read the ${project.title} blog post` },
  { label: labels.demo, href: project.demo, external: true, ariaLabel: `Open the ${project.title} live demo` },
];
---

<article
  class:list={["project-card", compact && "project-card-compact", selectedWork && "project-card-selected"]}
>
  {
    selectedWork ? (
      <a class="project-card-link" href={`/projects/${slug}/`} aria-label={`${labels.readAbout} ${project.title}`}>
        <span class="project-media">
          <img
            src={projectImagePath(project)}
            alt={`${project.title} ${labels.preview}`}
            loading="lazy"
            style={`view-transition-name: vt-project-${slug};`}
          />
        </span>
        <div class="project-card-body">
          <div class="project-card-topline">
            <span>{project.year}</span>
          </div>
          <h3>{project.title}</h3>
          <div class="project-card-copy">
            {selectedParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <span class="timeline-read-more project-card-read-more" aria-hidden="true">
            <span>{labels.readMore}</span>
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14" />
              <path d="m13 6 6 6-6 6" />
            </svg>
          </span>
        </div>
      </a>
    ) : (
      <>
        <a class="project-card-main-link" href={`/projects/${slug}/`} aria-label={`${labels.readAbout} ${project.title}`}></a>
        <span class="project-media" aria-hidden="true">
          <img
            src={projectImagePath(project)}
            alt={`${project.title} ${labels.preview}`}
            loading="lazy"
            style={`view-transition-name: vt-project-${slug};`}
          />
        </span>
        <div class="project-card-content">
          <div class="project-card-body">
            <div class="project-card-topline">
              <span>{project.year}</span>
            </div>
            <h3>{project.title}</h3>
            <div class="project-card-description">
              <p data-project-description-lang="en">{project.description}</p>
              {project.descriptionFi && <p data-project-description-lang="fi">{project.descriptionFi}</p>}
            </div>
          </div>
          <div class="project-card-actions" aria-label={`${project.title} links`}>
            {actions.map((action) =>
              action.href ? (
                <a
                  class="project-action"
                  href={action.href}
                  target={action.external ? "_blank" : undefined}
                  rel={action.external ? "noreferrer" : undefined}
                  aria-label={action.ariaLabel}
                >
                  {action.label}
                </a>
              ) : (
                <span class="project-action is-placeholder" aria-disabled="true" aria-label={`${action.label} placeholder for ${project.title}`}>
                  {action.label}
                </span>
              )
            )}
          </div>
        </div>
      </>
    )
  }
</article>
