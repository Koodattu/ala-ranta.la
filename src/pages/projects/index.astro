---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import projectsData from "../../data/projects.json";
import { getUniqueTags, slugify, sortNewestProjects, type Project } from "../../utils";

const projects = sortNewestProjects(projectsData.projects as Project[]);
const tags = getUniqueTags(projects);
---

<BaseLayout
  title="Projects"
  description="A collection of software projects by Juha Ala-Rantala, including full-stack apps, AI experiments, desktop tools, mobile apps, and static websites."
>
  <main>
    <section class="page-hero section-shell reveal">
      <p class="eyebrow">Projects</p>
      <h1>Software projects, experiments, and shipped tools</h1>
      <p>
        This archive is rendered as static HTML from project data, with a small client-side filter layered on top for
        convenience.
      </p>
    </section>

    <section class="section-shell">
      <div class="project-tools" data-project-tools data-reveal>
        <label class="search-field">
          <span>Search projects</span>
          <input type="search" name="project-search" placeholder="Search title, description, or tag" autocomplete="off" />
        </label>
        <div class="filter-controls" aria-label="Filter projects by technology">
          <button class="filter-button is-active" type="button" data-filter="all">All</button>
          {tags.map((tag) => (
            <button class="filter-button" type="button" data-filter={slugify(tag)}>{tag}</button>
          ))}
        </div>
        <p class="result-count" data-result-count>{projects.length} projects</p>
      </div>

      <div class="project-grid" data-project-grid data-reveal-group>
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </main>

  <script is:inline>
    const tools = document.querySelector("[data-project-tools]");
    const cards = Array.from(document.querySelectorAll("[data-project-card]"));
    const searchInput = tools?.querySelector("input[type='search']");
    const buttons = Array.from(tools?.querySelectorAll("[data-filter]") ?? []);
    const resultCount = tools?.querySelector("[data-result-count]");
    const params = new URLSearchParams(window.location.search);
    const initialTag = params.get("tag") ?? "all";
    let activeFilter = initialTag;

    const update = () => {
      const query = String(searchInput?.value ?? "").trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const title = card.getAttribute("data-title") ?? "";
        const description = card.getAttribute("data-description") ?? "";
        const tags = card.getAttribute("data-tags") ?? "";
        const matchesFilter = activeFilter === "all" || tags.split(" ").includes(activeFilter);
        const matchesQuery = !query || title.includes(query) || description.includes(query) || tags.includes(query);
        const shouldShow = matchesFilter && matchesQuery;

        card.toggleAttribute("hidden", !shouldShow);
        if (shouldShow) visible += 1;
      });

      if (resultCount) {
        resultCount.textContent = `${visible} ${visible === 1 ? "project" : "projects"}`;
      }
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        activeFilter = button.getAttribute("data-filter") ?? "all";
        buttons.forEach((item) => item.classList.toggle("is-active", item === button));
        update();
      });
    });

    const initialButton = buttons.find((button) => button.getAttribute("data-filter") === initialTag);
    if (initialButton) {
      buttons.forEach((item) => item.classList.toggle("is-active", item === initialButton));
    } else {
      activeFilter = "all";
    }

    searchInput?.addEventListener("input", update);
    update();
  </script>
</BaseLayout>
