---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import projectsData from "../../data/projects.json";
import { sortNewestProjects, type Project } from "../../utils";

const projects = sortNewestProjects(projectsData.projects as Project[]);
---

<BaseLayout
  title="Projects"
  description="A collection of software projects by Juha Ala-Rantala, including full-stack apps, AI experiments, desktop tools, mobile apps, and static websites."
>
  <main>
    <section class="page-hero section-shell reveal">
      <p class="eyebrow">Projects</p>
      <h1>Software projects, experiments, and shipped tools</h1>
      <p>
        Things I have built over the years: AI tools, game and stream utilities, mobile apps, dashboards, and small
        websites. Open the code, read the write-up when one exists, or try the live demo if it is still online.
      </p>
    </section>

    <section class="section-shell project-list-shell">
      <div class="project-list" data-project-list data-reveal-group>
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </main>
</BaseLayout>
