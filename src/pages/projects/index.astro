---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import projectsData from "../../data/projects.json";
import { sortNewestProjects, type Project } from "../../utils";

const projects = sortNewestProjects(projectsData.projects as Project[]);
---

<BaseLayout
  title="Projects"
  description="A collection of software projects by Juha Ala-Rantala, including full-stack apps, AI experiments, desktop tools, mobile apps, and static websites."
>
  <main>
    <section class="page-hero section-shell reveal">
      <p class="eyebrow">
        <span data-language-copy="en">Projects</span>
        <span data-language-copy="fi">Projektit</span>
      </p>
      <h1>
        <span data-language-copy="en">Software projects, experiments, and shipped tools</span>
        <span data-language-copy="fi">Ohjelmistoprojekteja, kokeiluja ja julkaistuja työkaluja</span>
      </h1>
      <p>
        <span data-language-copy="en">
          Things I have built over the years: AI tools, game and stream utilities, mobile apps, dashboards, and small
          websites. Open the code, read the write-up when one exists, or try the live demo if it is still online.
        </span>
        <span data-language-copy="fi">
          Vuosien varrella rakentamiani asioita: tekoälytyökaluja, peli- ja striimiapuohjelmia, mobiilisovelluksia,
          dashboardeja ja pieniä verkkosivustoja. Avaa lähdekoodi, lue kirjoitus kun sellainen on olemassa tai kokeile
          demoa, jos se on yhä verkossa.
        </span>
      </p>
    </section>

    <section class="section-shell project-list-shell">
      <div class="project-list" data-project-list data-reveal-group>
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </main>
</BaseLayout>
