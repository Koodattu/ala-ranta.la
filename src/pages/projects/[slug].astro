---
import BaseLayout from "../../layouts/BaseLayout.astro";
import projectsData from "../../data/projects.json";
import {
  getProjectSlug,
  projectImagePath,
  sortNewestProjects,
  type Project,
} from "../../utils";

export function getStaticPaths() {
  const projects = sortNewestProjects(projectsData.projects as Project[]);

  return projects.map((project) => ({
    params: { slug: getProjectSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };
const image = projectImagePath(project);
const projectDescriptions = [project.description, project.descriptionFi].filter(
  (description): description is string => Boolean(description),
);
const actions = [
  { label: "Source", href: project.source, external: true, className: "button button-primary" },
  { label: "Blog", href: project.blog, external: false, className: "button" },
  { label: "Demo", href: project.demo, external: true, className: "button" },
];
const schema = {
  "@type": "CreativeWork",
  name: project.title,
  description: project.description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  image: new URL(image, Astro.site).toString(),
  dateCreated: String(project.year),
  creator: { "@id": `${Astro.site}#person` },
  sameAs: [project.source, project.demo].filter(Boolean),
};
---

<BaseLayout title={project.title} description={project.description} image={image} schema={schema}>
  <main>
    <article>
      <header class="project-detail-hero section-shell">
        <div class="reveal">
          <p class="eyebrow">{project.year}</p>
          <h1>{project.title}</h1>
          <div class="project-detail-description">
            {projectDescriptions.map((description) => <p>{description}</p>)}
          </div>
          <div class="hero-actions">
            <div class="hero-action-row">
              {actions.map((action) =>
                action.href ? (
                  <a
                    class={action.className}
                    href={action.href}
                    target={action.external ? "_blank" : undefined}
                    rel={action.external ? "noreferrer" : undefined}
                  >
                    {action.label}
                  </a>
                ) : (
                  <span class={`${action.className} is-disabled`} aria-disabled="true">{action.label}</span>
                )
              )}
            </div>
            <a class="button" href="/projects/">All projects</a>
          </div>
        </div>
        <img src={image} alt={`${project.title} preview`} style={`view-transition-name: vt-project-${getProjectSlug(project)};`} />
      </header>

      <section class="section-shell split-section">
        <div class="section-heading sticky-heading" data-reveal>
          <p class="eyebrow">Details</p>
          <h2>What it does</h2>
        </div>
        <div class="prose-block" data-reveal-group>
          <ul class="feature-list feature-list-large">
            {project.features.map((feature) => <li>{feature}</li>)}
          </ul>
        </div>
      </section>
    </article>
  </main>
</BaseLayout>
