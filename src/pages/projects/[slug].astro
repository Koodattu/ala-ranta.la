---
import DetailBackNav from "../../components/DetailBackNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import projectsData from "../../data/projects.json";
import {
  getProjectSlug,
  projectImagePath,
  sortNewestProjects,
  type Project,
} from "../../utils";

export function getStaticPaths() {
  const projects = sortNewestProjects(projectsData.projects as Project[]);

  return projects.map((project) => ({
    params: { slug: getProjectSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };
const image = projectImagePath(project);
const actions = [
  { label: { en: "Source", fi: "Lähdekoodi" }, href: project.source, external: true, className: "button button-primary" },
  { label: { en: "Blog", fi: "Blogi" }, href: project.blog, external: false, className: "button" },
  { label: { en: "Demo", fi: "Demo" }, href: project.demo, external: true, className: "button" },
];
const featuresFi = project.featuresFi ?? project.features;
const schema = {
  "@type": "CreativeWork",
  name: project.title,
  description: project.description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  image: new URL(image, Astro.site).toString(),
  dateCreated: String(project.year),
  creator: { "@id": `${Astro.site}#person` },
  sameAs: [project.source, project.demo].filter(Boolean),
};
---

<BaseLayout title={project.title} description={project.description} image={image} schema={schema}>
  <main>
    <DetailBackNav
      sectionHref="/projects/"
      sectionLabel="Back to projects"
      sectionLabelFi="Takaisin projekteihin"
      ariaLabel="Project navigation"
      ariaLabelFi="Projektinavigaatio"
      previousLabelFi="Takaisin edelliselle sivulle"
    />
    <article>
      <header class="project-detail-hero section-shell">
        <div class="reveal">
          <p class="eyebrow">{project.year}</p>
          <h1>{project.title}</h1>
          <div class="project-detail-description">
            <p data-project-description-lang="en">{project.description}</p>
            {project.descriptionFi && <p data-project-description-lang="fi">{project.descriptionFi}</p>}
          </div>
          <div class="hero-actions">
            <div class="hero-action-row">
              {actions.map((action) =>
                action.href ? (
                  <a
                    class={action.className}
                    href={action.href}
                    target={action.external ? "_blank" : undefined}
                    rel={action.external ? "noreferrer" : undefined}
                  >
                    <span data-language-copy="en">{action.label.en}</span>
                    <span data-language-copy="fi">{action.label.fi}</span>
                  </a>
                ) : (
                  <span class={`${action.className} is-disabled`} aria-disabled="true">
                    <span data-language-copy="en">{action.label.en}</span>
                    <span data-language-copy="fi">{action.label.fi}</span>
                  </span>
                )
              )}
            </div>
          </div>
        </div>
        <img src={image} alt={`${project.title} preview`} style={`view-transition-name: vt-project-${getProjectSlug(project)};`} />
      </header>

      <section class="section-shell split-section">
        <div class="section-heading sticky-heading" data-reveal>
          <p class="eyebrow">
            <span data-language-copy="en">Details</span>
            <span data-language-copy="fi">Tiedot</span>
          </p>
          <h2>
            <span data-language-copy="en">What it does</span>
            <span data-language-copy="fi">Mitä se tekee</span>
          </h2>
        </div>
        <div class="prose-block" data-reveal-group>
          <ul class="feature-list feature-list-large" data-language-block="en">
            {project.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <ul class="feature-list feature-list-large" data-language-block="fi">
            {featuresFi.map((feature) => <li>{feature}</li>)}
          </ul>
        </div>
      </section>
    </article>
  </main>
</BaseLayout>
