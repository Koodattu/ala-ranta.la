---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TechTag from "../components/TechTag.astro";
import { careerSpine, currently, flagship, principles, profile } from "../data/profile";
import projectsData from "../data/projects.json";
import { formatDate, getProjectSlug, sortNewestProjects, type Project } from "../utils";

const projects = sortNewestProjects(projectsData.projects as Project[]);
const caseStudies = projects.slice(0, 2);
const experiments = projects.slice(2, 8);
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const readingTime = (body: string | undefined) =>
  Math.max(1, Math.round((body ?? "").split(/\s+/).filter(Boolean).length / 200));
---

<BaseLayout>
  <main>
    <section class="hero section-shell" aria-labelledby="intro-title">
      <div class="hero-copy reveal">
        <h1 id="intro-title">{profile.name}</h1>
        <p class="hero-tagline">{profile.tagline}</p>
        <p class="hero-lede">
          I build software products end to end — <strong>mobile</strong>, <strong>backend</strong>,
          <strong>infrastructure</strong>, and <strong>applied AI</strong> — and I stay for the part after the demo:
          deployment, real users, costs, and maintenance.
        </p>
        <p class="hero-proof">
          CTO at <a href="https://clevoy.io" target="_blank" rel="noreferrer">Clevoy</a>
          <span aria-hidden="true">·</span> M.Sc in IT, top-graded thesis
          <span aria-hidden="true">·</span> {profile.location}
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button button-primary" href={`mailto:${profile.email}`}>Get in touch</a>
          <a class="button" href="/projects/">View projects</a>
          <a class="button button-quiet" href={profile.cv.en}>View CV</a>
        </div>
      </div>

      <div class="hero-visual reveal">
        <svg
          class="system-map"
          viewBox="0 0 520 600"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path class="map-line" pathLength="1" d="M158 74 C 110 110, 82 150, 66 186" />
          <path class="map-line" pathLength="1" d="M184 72 C 220 96, 256 118, 278 138" />
          <path class="map-line" pathLength="1" d="M66 216 C 84 258, 108 296, 128 318" />
          <path class="map-line" pathLength="1" d="M282 166 C 240 222, 196 280, 156 318" />
          <path class="map-line" pathLength="1" d="M132 346 C 104 390, 80 432, 66 464" />
          <path class="map-line" pathLength="1" d="M152 344 C 178 396, 204 446, 222 486" />
          <g class="map-node map-node-warm" style="--map-delay: 0ms">
            <circle cx="170" cy="60" r="5" />
            <text x="170" y="40">Users</text>
          </g>
          <g class="map-node" style="--map-delay: 240ms">
            <circle cx="60" cy="200" r="5" />
            <text x="60" y="232">Mobile</text>
          </g>
          <g class="map-node" style="--map-delay: 240ms">
            <circle cx="290" cy="150" r="5" />
            <text x="290" y="130">Web</text>
          </g>
          <g class="map-node" style="--map-delay: 520ms">
            <circle cx="140" cy="332" r="5" />
            <text x="140" y="364">Backend</text>
          </g>
          <g class="map-node" style="--map-delay: 800ms">
            <circle cx="60" cy="480" r="5" />
            <text x="60" y="512">Infra</text>
          </g>
          <g class="map-node map-node-accent" style="--map-delay: 800ms">
            <circle cx="232" cy="502" r="5" />
            <text x="232" y="534">AI</text>
          </g>
        </svg>
        <img
          class="hero-photo"
          src="/assets/big-photo.webp"
          alt="Portrait of Juha Ala-Rantala"
          width="351"
          height="583"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </section>

    <section class="section-shell compact-section" aria-labelledby="currently-title">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Currently</p>
        <h2 id="currently-title">What I'm building right now</h2>
      </div>
      <div class="focus-grid" data-reveal-group>
        {currently.map((item) => (
          <article class="focus-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a
              class="text-link"
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {item.linkLabel}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section-shell" aria-labelledby="projects-title">
      <div class="section-heading section-heading-row" data-reveal>
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="projects-title">Projects with working code behind them</h2>
        </div>
        <a class="text-link" href="/projects/">All projects</a>
      </div>

      <article class="flagship-card" data-reveal>
        <div class="flagship-main">
          <p class="flagship-topline">
            <span class="flagship-label">{flagship.label}</span>
            <span class="flagship-status">{flagship.status}</span>
          </p>
          <h3 class="flagship-title">
            <a href={flagship.href} target="_blank" rel="noreferrer">{flagship.title}</a>
          </h3>
          <p class="flagship-role">{flagship.role}</p>
          <p>{flagship.text}</p>
          <p>{flagship.hard}</p>
          <div class="tag-list" aria-label={`${flagship.title} stack`}>
            {flagship.stack.map((tag) => <TechTag tag={tag} />)}
          </div>
        </div>
        <div class="flagship-aside" aria-hidden="true">
          <img src={flagship.logo} alt="" width="96" height="96" loading="lazy" decoding="async" />
        </div>
      </article>

      <div class="project-grid featured-project-grid" data-reveal-group>
        {caseStudies.map((project) => <ProjectCard project={project} />)}
      </div>

      <div class="experiments" data-reveal>
        <h3 class="experiments-title">Experiments and smaller tools</h3>
        <ol class="experiments-list">
          {experiments.map((project) => (
            <li>
              <a class="experiment-row" href={`/projects/${getProjectSlug(project)}/`}>
                <span class="experiment-year">{project.year}</span>
                <span class="experiment-name">{project.title}</span>
                <span class="experiment-arrow" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section-shell" aria-labelledby="principles-title">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Principles</p>
        <h2 id="principles-title">What I optimize for</h2>
      </div>
      <div class="principles-grid" data-reveal-group>
        {principles.map((principle) => (
          <article class="principle">
            <h3>{principle.title}</h3>
            <p>{principle.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-shell" aria-labelledby="career-title">
      <div class="section-heading section-heading-row" data-reveal>
        <div>
          <p class="eyebrow">Career</p>
          <h2 id="career-title">The short version</h2>
        </div>
        <a class="text-link" href="/about/">Full background</a>
      </div>
      <ol class="career-spine" data-reveal-group>
        {careerSpine.map((stop) => (
          <li class:list={["career-stop", stop.current && "is-current"]}>
            <span class="career-dot" aria-hidden="true"></span>
            <span class="career-year">{stop.year}</span>
            <span class="career-org">{stop.organization}</span>
            <span class="career-text">{stop.text}</span>
          </li>
        ))}
      </ol>
    </section>

    <section class="section-shell" aria-labelledby="writing-title">
      <div class="section-heading section-heading-row" data-reveal>
        <div>
          <p class="eyebrow">Writing</p>
          <h2 id="writing-title">Notes and longer-form posts</h2>
        </div>
        <a class="text-link" href="/blog/">All writing</a>
      </div>
      {posts.length > 0 ? (
        <ol class="writing-list" data-reveal-group>
          {posts.map((post) => (
            <li>
              <a class="writing-row" href={`/blog/${post.id}/`}>
                <time class="writing-date" datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                <span class="writing-name">{post.data.title}</span>
                <span class="writing-meta">{readingTime(post.body)} min read</span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p>No published posts yet.</p>
      )}
    </section>

    <section class="section-shell contact-cta" aria-labelledby="contact-title">
      <div class="contact-inner" data-reveal>
        <h2 id="contact-title">Want to build something that survives the demo?</h2>
        <p>
          I'm open to conversations about product engineering, applied AI, and technical leadership.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={`mailto:${profile.email}`}>Email Juha</a>
          <a class="button" href="https://www.linkedin.com/in/juha-ala-rantala/" target="_blank" rel="noreferrer">
            LinkedIn
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
