---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TechTag from "../components/TechTag.astro";
import Timeline from "../components/Timeline.astro";
import { education, experience, focusAreas, profile, skillGroups } from "../data/profile";
import projectsData from "../data/projects.json";
import { sortNewestProjects, type Project } from "../utils";

const projects = sortNewestProjects(projectsData.projects as Project[]);
const featuredProjects = projects.slice(0, 4);
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <main>
    <section class="hero section-shell" aria-labelledby="intro-title">
      <div class="hero-copy reveal">
        <p class="eyebrow">Software engineer in {profile.location}</p>
        <h1 id="intro-title">{profile.name}</h1>
        <p class="hero-lede">
          I build practical software products across mobile, backend, web, infrastructure, and applied AI. I like
          systems that are understandable, useful, and maintainable after the first demo.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button button-primary" href="/projects/">View projects</a>
          <a class="button" href="/blog/">Read writing</a>
          <a class="button button-quiet" href={profile.cv.en}>CV</a>
        </div>
      </div>

      <div class="hero-visual reveal">
        <img class="hero-photo" src="/assets/big-photo.png" alt="Portrait of Juha Ala-Rantala" />
      </div>
    </section>

    <section class="section-shell compact-section" aria-labelledby="focus-title">
      <div class="section-heading">
        <p class="eyebrow">Focus</p>
        <h2 id="focus-title">What I usually work on</h2>
      </div>
      <div class="focus-grid">
        {focusAreas.map((area) => (
          <article class="focus-card">
            <h3>{area.title}</h3>
            <p>{area.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-shell" aria-labelledby="projects-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="projects-title">Projects with working code behind them</h2>
        </div>
        <a class="text-link" href="/projects/">All projects</a>
      </div>
      <div class="project-grid featured-project-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="section-shell split-section" aria-labelledby="skills-title">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Stack</p>
        <h2 id="skills-title">Tools I reach for</h2>
        <p>
          The list changes over time, but the pattern is stable: use the boring tool when it is enough, and keep the
          experimental work contained until it proves itself.
        </p>
      </div>
      <div class="skill-groups">
        {skillGroups.map((group) => (
          <section class="skill-group" aria-labelledby={`skill-${group.title.toLowerCase()}`}>
            <h3 id={`skill-${group.title.toLowerCase()}`}>{group.title}</h3>
            <div class="tag-list">
              {group.skills.map((skill) => <TechTag tag={skill} />)}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="section-shell split-section" aria-labelledby="experience-title">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">Recent work</h2>
      </div>
      <Timeline items={experience} />
    </section>

    <section class="section-shell split-section" aria-labelledby="education-title">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Education</p>
        <h2 id="education-title">Formal background</h2>
      </div>
      <Timeline items={education} />
    </section>

    <section class="section-shell" aria-labelledby="writing-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Writing</p>
          <h2 id="writing-title">Notes and longer-form posts</h2>
        </div>
        <a class="text-link" href="/blog/">Blog archive</a>
      </div>
      <div class="post-grid">
        {posts.length > 0 ? posts.map((post) => <PostCard post={post} />) : <p>No published posts yet.</p>}
      </div>
    </section>
  </main>
</BaseLayout>
