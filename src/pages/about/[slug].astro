---
import TechTag from "../../components/TechTag.astro";
import DetailBackNav from "../../components/DetailBackNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localizedEducation, localizedExperience, type Locale } from "../../data/home";
import { profile } from "../../data/profile";
import { getBackgroundSlug, type BackgroundItem } from "../../utils";

type BackgroundKind = "company" | "school";
type BackgroundEntry = BackgroundItem & { kind: BackgroundKind };
type BackgroundGroup = {
  slug: string;
  organization: string;
  logo: string;
  url: string;
  kinds: BackgroundKind[];
  items: BackgroundEntry[];
};

type LocalizedBackgroundGroups = Record<Locale, BackgroundGroup>;

const locales: Locale[] = ["en", "fi"];
const backgroundCopy = {
  en: {
    categories: {
      combined: "Workplace and school",
      school: "School",
      company: "Company",
    },
    metaLabelSuffix: "background summary",
    officialSite: "Official site",
    backgroundEyebrow: "Background",
    multipleItemsTitle: "Roles and studies",
    singleItemTitle: "Role",
    workLabel: "Work",
    educationLabel: "Education",
  },
  fi: {
    categories: {
      combined: "Työpaikka ja koulu",
      school: "Koulu",
      company: "Yritys",
    },
    metaLabelSuffix: "taustan yhteenveto",
    officialSite: "Virallinen sivusto",
    backgroundEyebrow: "Tausta",
    multipleItemsTitle: "Roolit ja opinnot",
    singleItemTitle: "Rooli",
    workLabel: "Työ",
    educationLabel: "Koulutus",
  },
};

const getCategoryLabel = (group: BackgroundGroup, locale: Locale) => {
  const isCompany = group.kinds.includes("company");
  const isSchool = group.kinds.includes("school");

  if (isCompany && isSchool) return backgroundCopy[locale].categories.combined;
  if (isSchool) return backgroundCopy[locale].categories.school;
  return backgroundCopy[locale].categories.company;
};

const getHeroSummary = (group: BackgroundGroup, locale: Locale) => {
  if (group.items.length === 1) return group.items[0].summary;

  const roles = group.items.map((item) => item.role).join("; ");

  return locale === "fi"
    ? `Taustani organisaatiossa ${group.organization} sisältää sekä työtä että opintoja: ${roles}.`
    : `My background with ${group.organization} includes both work and studies: ${roles}.`;
};

export function getStaticPaths() {
  const createBackgroundGroups = (experienceItems: BackgroundItem[], educationItems: BackgroundItem[]) => {
    const backgroundItems: BackgroundEntry[] = [
      ...experienceItems.map((item) => ({ ...item, kind: "company" as const })),
      ...educationItems.map((item) => ({ ...item, kind: "school" as const })),
    ];
    const groups = new Map<string, BackgroundGroup>();

    for (const item of backgroundItems) {
      const slug = getBackgroundSlug(item);
      const group = groups.get(slug);

      if (group) {
        group.items.push(item);

        if (!group.kinds.includes(item.kind)) {
          group.kinds.push(item.kind);
        }

        continue;
      }

      groups.set(slug, {
        slug,
        organization: item.organization,
        logo: item.logo,
        url: item.url,
        kinds: [item.kind],
        items: [item],
      });
    }

    return groups;
  };

  const englishGroups = createBackgroundGroups(localizedExperience.en, localizedEducation.en);
  const finnishGroups = createBackgroundGroups(localizedExperience.fi, localizedEducation.fi);

  return [...englishGroups.values()].map((group) => ({
    params: { slug: group.slug },
    props: {
      groups: {
        en: group,
        fi: finnishGroups.get(group.slug) ?? group,
      },
    },
  }));
}

const { groups } = Astro.props as { groups: LocalizedBackgroundGroups };
const group = groups.en;
const isCompany = group.kinds.includes("company");
const isSchool = group.kinds.includes("school");
const categoryLabel = getCategoryLabel(group, "en");
const description = `Background page for ${profile.name}'s ${categoryLabel.toLowerCase()} experience at ${group.organization}.`;
const schema = {
  "@type": isSchool && !isCompany ? "CollegeOrUniversity" : "Organization",
  name: group.organization,
  url: group.url,
  logo: new URL(group.logo, Astro.site).toString(),
};
---

<BaseLayout title={group.organization} description={description} image={group.logo} schema={schema}>
  <main>
    <DetailBackNav
      sectionHref="/about/"
      sectionLabel="Back to about"
      sectionLabelFi="Takaisin tietoa-sivulle"
      ariaLabel="Background navigation"
      ariaLabelFi="Taustanavigaatio"
      previousLabelFi="Takaisin edelliselle sivulle"
    />
    <article>
      <header class="about-detail-hero section-shell">
        <div class="reveal">
          <p class="eyebrow">
            <span data-language-copy="en">{getCategoryLabel(groups.en, "en")}</span>
            <span data-language-copy="fi">{getCategoryLabel(groups.fi, "fi")}</span>
          </p>
          <h1>{group.organization}</h1>
          {locales.map((locale) => (
            <p data-language-block={locale}>{getHeroSummary(groups[locale], locale)}</p>
          ))}
          {locales.map((locale) => (
            <ul class="about-detail-meta" aria-label={`${groups[locale].organization} ${backgroundCopy[locale].metaLabelSuffix}`} data-language-block={locale}>
              {groups[locale].items.map((item) => (
                <li>{item.period}</li>
              ))}
            </ul>
          ))}
          <div class="hero-actions">
            <div class="hero-action-row">
              <a class="button button-primary" href={group.url} target="_blank" rel="noreferrer">
                <span data-language-copy="en">{backgroundCopy.en.officialSite}</span>
                <span data-language-copy="fi">{backgroundCopy.fi.officialSite}</span>
              </a>
            </div>
          </div>
        </div>
        <div class="about-detail-logo-card" aria-hidden="true">
          <img
            class:list={["about-detail-logo", group.logo.includes("clevoy") && "about-detail-logo-wide"]}
            src={group.logo}
            alt=""
          />
        </div>
      </header>

      <section class="section-shell split-section">
        <div class="section-heading sticky-heading" data-reveal>
          <p class="eyebrow">
            <span data-language-copy="en">{backgroundCopy.en.backgroundEyebrow}</span>
            <span data-language-copy="fi">{backgroundCopy.fi.backgroundEyebrow}</span>
          </p>
          <h2>
            <span data-language-copy="en">
              {group.items.length > 1 ? backgroundCopy.en.multipleItemsTitle : backgroundCopy.en.singleItemTitle}
            </span>
            <span data-language-copy="fi">
              {groups.fi.items.length > 1 ? backgroundCopy.fi.multipleItemsTitle : backgroundCopy.fi.singleItemTitle}
            </span>
          </h2>
        </div>
        {locales.map((locale) => (
          <div data-language-block={locale}>
            <div class="background-entry-list" data-reveal-group>
              {groups[locale].items.map((item) => (
                <article class="background-entry">
                  <div class="background-entry-header">
                    <div>
                      <p class="timeline-period">{item.kind === "company" ? backgroundCopy[locale].workLabel : backgroundCopy[locale].educationLabel}</p>
                      <h3>{item.role}</h3>
                    </div>
                    <p class="background-entry-period">{item.period}</p>
                  </div>
                  <p>{item.summary}</p>
                  <ul class="feature-list">
                    {item.details.map((detail) => <li>{detail}</li>)}
                  </ul>
                  <div class="tag-list">
                    {item.tags.map((tag) => <TechTag tag={tag} muted />)}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </section>
    </article>
  </main>
</BaseLayout>
