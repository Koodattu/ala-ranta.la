---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/profile";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  lang?: "en" | "fi";
  alternates?: { lang: string; href: string }[];
  xDefaultHref?: string;
  enableLocaleRedirect?: boolean;
  languageHrefs?: Partial<Record<"en" | "fi", string>>;
}

const {
  title = `${profile.name} - ${profile.role}`,
  description = profile.description,
  image = "/images/preview.jpg",
  type = "website",
  noIndex = false,
  schema = [],
  lang = "en",
  alternates = [],
  xDefaultHref,
  enableLocaleRedirect = false,
  languageHrefs,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();
const pageTitle = title.includes(profile.name) ? title : `${title} - ${profile.siteName}`;
const absoluteHref = (href: string) => new URL(href, Astro.site).toString();

const defaultSchema = [
  {
    "@type": "Person",
    "@id": `${Astro.site}#person`,
    name: profile.name,
    url: Astro.site,
    image: new URL(profile.image, Astro.site).toString(),
    jobTitle: profile.role,
    email: profile.email,
    sameAs: profile.socials.filter((social) => social.href.startsWith("http")).map((social) => social.href),
  },
  {
    "@type": "WebSite",
    "@id": `${Astro.site}#website`,
    url: Astro.site,
    name: profile.siteName,
    description: profile.description,
    publisher: { "@id": `${Astro.site}#person` },
  },
];

const schemaItems = Array.isArray(schema) ? schema : [schema];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [...defaultSchema, ...schemaItems],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={absoluteHref(alternate.href)} />
    ))}
    {xDefaultHref && <link rel="alternate" hreflang="x-default" href={absoluteHref(xDefaultHref)} />}
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${profile.siteName} RSS`} href="/rss.xml" />
    <meta name="theme-color" content="#2dd4bf" />
    <script is:inline>
      (() => {
        const getSupportedLanguage = (language) => {
          const baseLanguage = language?.toLowerCase().split("-")[0];
          return baseLanguage === "en" || baseLanguage === "fi" ? baseLanguage : undefined;
        };

        const params = new URLSearchParams(window.location.search);
        const requestedLanguage = getSupportedLanguage(params.get("lang"));
        const pageLanguage = getSupportedLanguage(document.documentElement.lang);

        if (requestedLanguage || pageLanguage === "fi") {
          try {
            window.localStorage.setItem("preferredLanguage", requestedLanguage ?? pageLanguage);
          } catch {
            // Keep the in-memory preference if storage is unavailable.
          }
        }

        let preferredLanguage;

        try {
          preferredLanguage = getSupportedLanguage(window.localStorage.getItem("preferredLanguage"));
        } catch {
          preferredLanguage = undefined;
        }

        const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
        const detectedLanguage = languages.map(getSupportedLanguage).find(Boolean);
        const selectedLanguage =
          requestedLanguage ?? preferredLanguage ?? (pageLanguage === "fi" ? "fi" : detectedLanguage) ?? pageLanguage ?? "en";

        document.documentElement.dataset.preferredLanguage = selectedLanguage;
      })();
    </script>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {enableLocaleRedirect && (
      <script is:inline>
        (() => {
          if (window.location.pathname !== "/") return;

          const getSupportedLanguage = (language) => {
            const baseLanguage = language?.toLowerCase().split("-")[0];
            return baseLanguage === "en" || baseLanguage === "fi" ? baseLanguage : undefined;
          };

          const params = new URLSearchParams(window.location.search);
          const requestedLanguage = getSupportedLanguage(params.get("lang"));

          if (requestedLanguage) {
            try {
              window.localStorage.setItem("preferredLanguage", requestedLanguage);
            } catch {
              // Continue with this page-load preference even if storage is unavailable.
            }
          }

          let preferredLanguage;

          try {
            preferredLanguage = getSupportedLanguage(window.localStorage.getItem("preferredLanguage"));
          } catch {
            preferredLanguage = undefined;
          }

          const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
          const detectedLanguage = languages.map(getSupportedLanguage).find(Boolean);
          const selectedLanguage = requestedLanguage ?? preferredLanguage ?? detectedLanguage ?? "en";

          if (selectedLanguage === "en") {
            if (requestedLanguage === "en") {
              window.history.replaceState({}, "", "/");
            }
            return;
          }

          if (selectedLanguage === "fi") {
            window.location.replace("/fi/");
          }
        })();
      </script>
    )}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  </head>
  <body>
    <Header lang={lang} languageHrefs={languageHrefs} />
    <div class="page-transition-content">
      <slot />
      <Footer lang={lang} />
    </div>
    <script>
      const syncPreferredLanguage = (language: string | undefined) => {
        if (language !== "en" && language !== "fi") return;

        document.documentElement.lang = language;
        document.documentElement.dataset.preferredLanguage = language;

        document.querySelectorAll("[data-language-choice]").forEach((link) => {
          if (link.getAttribute("data-language-choice") === language) {
            link.setAttribute("aria-current", "true");
          } else {
            link.removeAttribute("aria-current");
          }
        });

        document.querySelectorAll("[data-language-aria-en][data-language-aria-fi]").forEach((element) => {
          const localizedLabel = element.getAttribute(`data-language-aria-${language}`);

          if (localizedLabel) {
            element.setAttribute("aria-label", localizedLabel);
          }
        });

        document.querySelectorAll("[data-language-href-en][data-language-href-fi]").forEach((element) => {
          const localizedHref = element.getAttribute(`data-language-href-${language}`);

          if (localizedHref) {
            element.setAttribute("href", localizedHref);
          }
        });
      };

      syncPreferredLanguage(document.documentElement.dataset.preferredLanguage);

      document.querySelectorAll("[data-language-choice]").forEach((link) => {
        link.addEventListener("click", () => {
          const selectedLanguage = link.getAttribute("data-language-choice") ?? undefined;

          try {
            window.localStorage.setItem("preferredLanguage", selectedLanguage ?? "");
          } catch {
            // Ignore storage failures and keep the link as a normal navigation control.
          }
        });
      });

      document.querySelectorAll<HTMLAnchorElement>('a[aria-current="page"]').forEach((link) => {
        link.addEventListener("click", (event) => {
          const targetUrl = new URL(link.href, window.location.href);

          if (
            targetUrl.origin === window.location.origin &&
            targetUrl.pathname === window.location.pathname &&
            targetUrl.search === window.location.search &&
            targetUrl.hash === window.location.hash
          ) {
            event.preventDefault();
          }
        });
      });

      const revealables = document.querySelectorAll("[data-reveal], [data-reveal-group]");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);

                if (entry.target.hasAttribute("data-reveal-group")) {
                  window.setTimeout(() => entry.target.classList.add("has-revealed"), 960);
                }
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px" }
        );

        revealables.forEach((el) => observer.observe(el));
      } else {
        revealables.forEach((el) => el.classList.add("is-visible", "has-revealed"));
      }
    </script>
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "48f8ea752d46437b91a38bb5742611b4"}'></script>
  </body>
</html>
